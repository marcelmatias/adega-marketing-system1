# ====================================================================
# VARIAVEIS OBRIGATORIAS - devem ser configuradas em producao
# ====================================================================
MONGODB_URI=mongodb://localhost:27017/adega_marketing
# Para Docker: MONGODB_URI=mongodb://mongodb:27017/adega_marketing
JWT_SECRET=adega_jwt_secret_change_in_production
SESSION_SECRET=adega_session_secret_change_in_production

# ====================================================================
# VARIAVEIS OPCIONAIS
# ====================================================================
PORT=3000
NODE_ENV=development
JWT_EXPIRES_IN=7d
BASE_URL=http://localhost:3000

# Canva - configurado via painel admin
CANVA_API_KEY=
CANVA_API_SECRET=
CANVA_MOCK=true

# Google OAuth (login social)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook OAuth (login social)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Asaas - PIX (configurado via painel super admin)
# ASAAS_API_KEY=
# ASAAS_ENVIRONMENT=sandbox

# Stripe - Cartao de credito (configurado via painel super admin)
# STRIPE_SECRET_KEY=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_WEBHOOK_SECRET=
