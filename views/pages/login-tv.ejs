<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login TV - Rei da Adega</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
    .tv-card { background: #0f0f1a; border: 1px solid #2a2a4a; border-radius: 16px; padding: 2rem; width: 100%; max-width: 400px; }
    .tv-card .icon { font-size: 3rem; color: #dc3545; }
    .tv-card h3 { color: #fff; }
    .tv-card .form-label { color: #aaa; }
    .tv-card .form-control { background: #1a1a2e; border: 1px solid #2a2a4a; color: #fff; }
    .tv-card .form-control:focus { background: #1a1a2e; border-color: #dc3545; box-shadow: 0 0 0 0.2rem rgba(220,53,69,0.25); color: #fff; }
    .tv-card .form-control::placeholder { color: #555; }
  </style>
</head>
<body>
  <div class="tv-card text-center">
    <i class="bi bi-tv icon"></i>
    <h3 class="mt-2">TV Login</h3>
    <p class="text-muted small">Acesse o player da sua TV</p>

    <% if (error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger py-2 small"><%= error_msg.join(', ') %></div>
    <% } %>

    <form action="/api/auth/login-tv" method="POST" class="text-start mt-3">
      <div class="mb-3">
        <label class="form-label small">Email</label>
        <input type="email" name="email" class="form-control" placeholder="tv@adega.com" required>
      </div>
      <div class="mb-3">
        <label class="form-label small">Senha</label>
        <input type="password" name="senha" class="form-control" placeholder="123456" required>
      </div>
      <button type="submit" class="btn btn-danger w-100 mt-2">
        <i class="bi bi-tv"></i> Entrar na TV
      </button>
    </form>
  </div>
</body>
</html>