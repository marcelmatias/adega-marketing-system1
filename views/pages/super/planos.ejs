<%- include('../../partials/header') %>
<%- include('../../partials/navbar') %>

<div class="container-fluid p-4">
  <h4 class="mb-4"><i class="bi bi-box"></i> Planos</h4>
  <div class="row g-3">
    <div class="col-md-3">
      <div class="list-group">
        <a href="/admin/super" class="list-group-item list-group-item-action"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a href="/admin/super/configuracoes" class="list-group-item list-group-item-action"><i class="bi bi-gear"></i> Configuracoes</a>
        <a href="/admin/super/adegas" class="list-group-item list-group-item-action"><i class="bi bi-shop"></i> Adegas</a>
        <a href="/admin/super/usuarios" class="list-group-item list-group-item-action"><i class="bi bi-people"></i> Usuarios</a>
        <a href="/admin/super/planos" class="list-group-item list-group-item-action active"><i class="bi bi-box"></i> Planos</a>
        <a href="/admin/super/modulos" class="list-group-item list-group-item-action"><i class="bi bi-puzzle"></i> Modulos</a>
        <a href="/admin/super/pagamentos" class="list-group-item list-group-item-action"><i class="bi bi-credit-card"></i> Pagamentos</a>
      </div>
    </div>
    <div class="col-md-9">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between">
          <h6 class="mb-0">Gerenciar Planos</h6>
          <button class="btn btn-sm btn-danger" onclick="novoPlano()"><i class="bi bi-plus-lg"></i> Novo</button>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive"><table class="table table-sm mb-0"><thead><tr><th>Nome</th><th>Slug</th><th>Preco Mensal</th><th>Preco Anual</th><th>Modulos</th><th>Ordem</th><th>Ativo</th><th>Acoes</th></tr></thead><tbody id="listaPlanos"></tbody></table></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
async function carregarPlanos() {
  const data = await api('/api/planos');
  const tbody = document.getElementById('listaPlanos');
  (data.planos || []).forEach(p => {
    tbody.innerHTML += '<tr><td>' + p.nome + '</td><td>' + p.slug + '</td><td>R$ ' + p.precoMensal.toFixed(2).replace('.',',') + '</td><td>R$ ' + (p.precoAnual || 0).toFixed(2).replace('.',',') + '</td><td><small>' + (p.modulos || []).join(', ') + '</small></td><td>' + p.ordem + '</td><td><span class="badge bg-' + (p.ativo ? 'success' : 'secondary') + '">' + (p.ativo ? 'Sim' : 'Nao') + '</span></td><td><button class="btn btn-sm btn-outline-info" onclick="alert(\'Editar via MongoDB shell ou API\')"><i class="bi bi-pencil"></i></button></td></tr>';
  });
}
carregarPlanos();

function novoPlano() {
  alert('Crie planos via seed ou MongoDB. Em breve: interface de criacao.');
}
</script>
<%- include('../../partials/footer') %>