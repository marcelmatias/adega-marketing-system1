{
  "name": "adega-marketing-system",
  "version": "2.0.0",
  "description": "Sistema completo de gestao para adegas com automacao de marketing, Canva, YouTube e player TV",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed/seed.js",
    "docker:setup": "docker compose build && docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:rebuild": "docker compose down && docker compose build --no-cache && docker compose up -d"
  },
  "dependencies": {
    "axios": "^1.7.5",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "connect-flash": "^0.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.1",
    "express-session": "^1.18.0",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^140.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.6.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^8.0.7",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.18.0",
    "sharp": "^0.34.5",
    "stripe": "^22.1.1",
    "tslib": "^2.8.1",
    "youtube-dl-exec": "^3.1.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
